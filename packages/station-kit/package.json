{
  "name": "station-kit",
  "version": "1.0.6",
  "description": "Dashboard for station-signal — inspect and control signals and broadcasts",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "station": "./dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    ".next/standalone",
    "src",
    "next.config.ts",
    "tsconfig.next.json"
  ],
  "scripts": {
    "build": "tsc && next build && cp -r .next/static .next/standalone/packages/station-kit/.next/static",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "station-signal": "workspace:*",
    "station-broadcast": "workspace:*"
  },
  "dependencies": {
    "hono": "^4",
    "@hono/node-server": "^1",
    "better-sqlite3": "^11.9.1",
    "ws": "^8",
    "tsx": "^4.21.0",
    "next": "^15",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "station-signal": "workspace:*",
    "station-broadcast": "workspace:*",
    "typescript": "^5.9.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8"
  }
}
