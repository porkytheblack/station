{
  "name": "station-adapter-postgres",
  "version": "1.0.1",
  "description": "PostgreSQL adapter for station-signal and station-broadcast",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./broadcast": {
      "types": "./dist/broadcast.d.ts",
      "import": "./dist/broadcast.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11"
  },
  "peerDependencies": {
    "station-signal": "workspace:*",
    "station-broadcast": "workspace:*"
  }
}
