{
  "name": "@simple-signal/adapter-sqlite",
  "version": "1.0.0",
  "description": "SQLite adapter for simple-signal using better-sqlite3",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./broadcast": {
      "types": "./dist/broadcast.d.ts",
      "import": "./dist/broadcast.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  },
  "peerDependencies": {
    "simple-signal": "workspace:*",
    "simple-broadcast": "workspace:*"
  }
}
